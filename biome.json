{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "files": {
    "includes": ["src/**", "tests/**", "scripts/**", "*.ts", "*.json", "index.html"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": { "maxAllowedComplexity": 15 }
        },
        "noExcessiveLinesPerFunction": {
          "level": "error",
          "options": { "maxLines": 100, "skipBlankLines": true }
        }
      },
      "correctness": {
        "noUnusedVariables": "error",
        "useExhaustiveDependencies": "error",
        "useHookAtTopLevel": "error",
        "useJsxKeyInIterable": "error"
      },
      "style": {
        "useConst": "error",
        "noNonNullAssertion": "error",
        "useImportType": "error",
        "useExportType": "error",
        "noDescendingSpecificity": "off"
      },
      "suspicious": {
        "noVar": "error",
        "noExplicitAny": "error",
        "noDoubleEquals": "error",
        "noArrayIndexKey": "error",
        "noConsole": {
          "level": "error",
          "options": { "allow": ["error", "info", "warn", "debug"] }
        }
      },
      "security": {
        "noDangerouslySetInnerHtml": "error",
        "noBlankTarget": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/core/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "react": "Engine (src/core) must be pure — no React (Constitution Principle I).",
                  "react-dom": "Engine (src/core) must be pure — no React DOM (Constitution Principle I).",
                  "@ui": "Engine (src/core) must not import the UI layer.",
                  "@ui/lib/logger": "Engine must not depend on UI logging."
                }
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "src/cli/**",
        "scripts/**",
        "**/__tests__/**",
        "**/*.test.ts",
        "**/*.test.tsx",
        "tests/**"
      ],
      "linter": { "rules": { "suspicious": { "noConsole": "off" } } }
    },
    {
      "includes": [
        "src/ui/components/CoinView.tsx",
        "src/ui/components/GridView.tsx",
        "src/ui/components/FaceSelector.tsx",
        "src/ui/components/SetupScreen.tsx",
        "src/ui/components/mobile/MobileBoard.tsx",
        "src/ui/components/mobile/BottomSheet.tsx",
        "src/ui/components/mobile/Drawer.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": { "useSemanticElements": "off", "noStaticElementInteractions": "off" }
        }
      }
    },
    {
      "includes": [
        "src/ui/components/mobile/MobileBoard.tsx",
        "src/ui/components/mobile/BottomSheet.tsx"
      ],
      "linter": { "rules": { "suspicious": { "noArrayIndexKey": "off" } } }
    },
    {
      "includes": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/__tests__/**",
        "tests/**",
        "src/ui/components/**",
        "src/ui/pages/**",
        "src/ui/App.tsx",
        "src/ui/main.tsx"
      ],
      "linter": { "rules": { "complexity": { "noExcessiveLinesPerFunction": "off" } } }
    }
  ]
}
