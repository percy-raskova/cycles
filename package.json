{
  "name": "cycles",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:verbose": "vitest run --reporter=verbose",
    "test:watch": "vitest --ui",
    "test:report": "open test-results/vitest-report.html 2>/dev/null || xdg-open test-results/vitest-report.html",
    "test:coverage": "vitest run --coverage",
    "test:coverage:open": "open coverage/index.html 2>/dev/null || xdg-open coverage/index.html",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "open playwright-report/index.html 2>/dev/null || xdg-open playwright-report/index.html",
    "lint": "biome check --error-on-warnings .",
    "lint:write": "biome check --write --error-on-warnings .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "cli": "bun run src/cli/main.ts",
    "lint:staged": "lint-staged"
  },
  "devDependencies": {
    "@biomejs/biome": "2",
    "@playwright/test": "^1.60.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser": "^4.1.7",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.8",
    "axe-core": "^4.11.4",
    "fast-check": "^3.23.1",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.2.10",
    "playwright": "^1.60.0",
    "simple-git-hooks": "^2.11.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint:staged && bun run typecheck && bun run test:run"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "biome check --write --no-errors-on-unmatched --error-on-warnings"
    ]
  }
}
